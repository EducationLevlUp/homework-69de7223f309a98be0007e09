# LLM Configuration (required)
# Format: provider:model (e.g., openai:gpt-4o, anthropic:claude-3-opus-20240229)
LLM_MODEL=openai:gpt-4o

# OpenAI API key (required if using openai provider)
OPENAI_API_KEY=your_openai_api_key_here

# Export directory for virtual files (optional, defaults to ./exported_files)
EXPORT_DIR=./exported_files

# Thread ID for agent session (optional, auto-generated if not set)
THREAD_ID=
